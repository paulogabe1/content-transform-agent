# When used standalone (cloned on its own, not nested inside
# growth-intel-agent), GROQ_API_KEY needs to be set directly here.
# There's no shared parent .env to inherit from in that case.
#
# When used nested inside growth-intel-agent (as its submodule), this
# still works exactly the same way, but GROQ_API_KEY and GROQ_MODEL
# can instead be left unset here and inherited from the shared
# ../.env. Only set them here if this project specifically needs a
# different value than the rest of the system.

# Get a free key (no card required) at https://console.groq.com/keys
# GROQ_API_KEY=your-key-here

# Optional. Defaults to groq/llama-3.3-70b-versatile if unset.
# Check https://console.groq.com/docs/models for current free-tier models.
# GROQ_MODEL=groq/llama-3.3-70b-versatile

# These chunking controls are specific to this project. There's no
# shared equivalent to inherit, since only this pipeline handles long
# transcripts this way. Controls when long transcripts (e.g. YouTube
# videos) get split into chunks before hitting the pipeline. Defaults
# are conservative on purpose: conversational content (fillers,
# contractions, dialogue punctuation) tokenizes less efficiently than
# clean prose, and the 12,000 tokens/minute limit is cumulative across
# calls, not just a per-request cap. If you're on a paid tier or a
# different model with a much higher limit, raise these. There's no
# automatic detection of your actual rate limit.
# MAX_SAFE_CHARS=12000
# CHUNK_SIZE_CHARS=8000
# CHUNK_DELAY_SECONDS=5
