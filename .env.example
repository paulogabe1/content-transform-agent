# Copy this file to .env and fill in your key.
# Get a free key (no card required) at https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Optional -- defaults to groq/llama-3.3-70b-versatile if unset.
# Check https://console.groq.com/docs/models for current free-tier models.
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Optional -- controls when long transcripts (e.g. YouTube videos) get
# split into chunks before hitting the pipeline. Defaults are
# conservative on purpose: conversational content (fillers,
# contractions, dialogue punctuation) tokenizes less efficiently than
# clean prose, and the 12,000 tokens/minute limit is cumulative across
# calls, not just a per-request cap. If you're on a paid tier or a
# different model with a much higher limit, raise these -- there's no
# automatic detection of your actual rate limit.
# MAX_SAFE_CHARS=12000
# CHUNK_SIZE_CHARS=8000
# CHUNK_DELAY_SECONDS=30
