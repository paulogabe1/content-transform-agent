# Standalone: set GROQ_API_KEY here, no parent .env to inherit from.
# Nested in growth-intel-agent: leave GROQ_API_KEY/GROQ_MODEL unset
# here to inherit from ../.env -- only set them if this project needs
# a different value.

# Get a free key (no card required) at https://console.groq.com/keys
# GROQ_API_KEY=your-key-here

# Optional. Defaults to groq/llama-3.3-70b-versatile if unset.
# Check https://console.groq.com/docs/models for current free-tier models.
# GROQ_MODEL=groq/llama-3.3-70b-versatile

# Controls when long transcripts get split into chunks before hitting
# the pipeline. Defaults are conservative -- conversational text
# tokenizes worse than clean prose, and Groq's 12k tokens/min limit is
# cumulative across calls. Raise these if you're on a bigger tier.
# MAX_SAFE_CHARS=12000
# CHUNK_SIZE_CHARS=8000
# CHUNK_DELAY_SECONDS=20
